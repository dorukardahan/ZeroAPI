{
  "name": "zeroapi",
  "version": "3.8.32",
  "private": true,
  "description": "ZeroAPI - transparent subscription-aware model and account routing for OpenClaw",
  "type": "module",
  "scripts": {
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:zeroapi",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.2"
    },
    "compat": {
      "pluginApi": ">=2026.5.2",
      "minGatewayVersion": "2026.5.2"
    },
    "build": {
      "openclawVersion": "2026.5.2",
      "pluginSdkVersion": "2026.5.2"
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
